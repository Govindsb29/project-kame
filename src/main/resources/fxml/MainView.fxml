<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="io.projectkame.view.MainController">

    <top>
        <HBox style="-fx-background-color:#2b2b2b;">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>

            <children>
                <Label text="Project Kame"
                       style="-fx-text-fill:white;
                              -fx-font-size:22px;
                              -fx-font-weight:bold;"/>
            </children>

        </HBox>
    </top>

    <left>

        <VBox spacing="15"
              prefWidth="220">

            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <children>

                <Button fx:id="openBackupButton"
                        text="Open Mihon Backup"
                        prefWidth="180"/>

                <Separator/>

                <Label text="Status"/>

                <Label fx:id="statusLabel"
                       text="No backup loaded."/>

            </children>

        </VBox>

    </left>

    <center>

        <SplitPane dividerPositions="0.35">

            <items>

                <VBox spacing="10">

                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <children>

                        <Label text="Library"
                               style="-fx-font-size:18px;
                                      -fx-font-weight:bold;"/>

                        <TextField fx:id="searchField"
                                   promptText="Search..."/>

                        <ListView fx:id="libraryList"/>

                    </children>

                </VBox>

                <VBox spacing="10">

                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <children>

                        <Label text="Details"
                               style="-fx-font-size:18px;
                                      -fx-font-weight:bold;"/>

                        <TextArea fx:id="statusArea"
                                  editable="false"
                                  wrapText="true"
                                  VBox.vgrow="ALWAYS"/>

                    </children>

                </VBox>

            </items>

        </SplitPane>

    </center>

</BorderPane>